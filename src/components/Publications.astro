---
import { CLUSTERS } from '../lib/clusters';

const articles = CLUSTERS.flatMap((cluster) =>
  cluster.leaves.map((leaf) => ({ ...leaf, cluster: cluster.id, clusterLabel: cluster.label })),
).sort((a, b) => (b.year ?? 0) - (a.year ?? 0));

const filters = [{ id: 'all', label: 'All areas' }, ...CLUSTERS.map((cluster) => ({ id: cluster.id, label: cluster.label }))];
---

<section id="publications" class="section publications" aria-labelledby="publications-title">
  <div class="wrap">
    <div class="section-index reveal">
      <span>09</span><i aria-hidden="true"></i><span>Selected publications</span>
    </div>
    <div class="publications-heading" data-reveal-group>
      <div>
        <p class="eyebrow reveal">Selected work</p>
        <h2 id="publications-title" class="t-section font-display reveal">A usable index to the research.</h2>
      </div>
      <div class="publication-actions reveal">
        <a class="button button-primary" href="/assets/femida-handy-cv.pdf" target="_blank" rel="noopener">Full CV</a>
        <a class="text-link" href="https://orcid.org/0000-0003-3200-8042" target="_blank" rel="noopener">ORCID <span aria-hidden="true">↗</span></a>
      </div>
    </div>

    <div class="publication-filter reveal">
      <span class="filter-index" aria-hidden="true"><i></i><b></b><i></i></span>
      <div role="group" aria-label="Filter publications by research area">
        {filters.map((filter, index) => (
          <button class:list={['publication-chip', { 'is-active': index === 0 }]} data-filter={filter.id} aria-pressed={index === 0 ? 'true' : 'false'}>
            {filter.label}
          </button>
        ))}
      </div>
    </div>

    <p id="filter-status" class="sr-only" aria-live="polite"></p>
    <ul class="publication-list" id="publication-list">
      {articles.map((article) => (
        <li data-cluster={article.cluster}>
          <span class="publication-year font-display">{article.status ?? article.year}</span>
          <span class="publication-title">{article.title}</span>
          <span class="publication-area">{article.clusterLabel}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.publication-chip'));
  const items = Array.from(document.querySelectorAll<HTMLLIElement>('.publication-list li'));
  const status = document.getElementById('filter-status');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const selected = chip.dataset.filter;
      chips.forEach((candidate) => {
        const active = candidate === chip;
        candidate.classList.toggle('is-active', active);
        candidate.setAttribute('aria-pressed', String(active));
      });
      let count = 0;
      items.forEach((item) => {
        const visible = selected === 'all' || item.dataset.cluster === selected;
        item.hidden = !visible;
        if (visible) count += 1;
      });
      if (status) status.textContent = `${count} selected publications shown`;
    });
  });
</script>
